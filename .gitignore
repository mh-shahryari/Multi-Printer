# ═══════════════════════════════════════════════════
# Multi Printer Monitoring - .gitignore
# ═══════════════════════════════════════════════════

# ─── فایل‌های داده‌ای و لاگ ─────────────────────────
*.db
*.log
*.sqlite
*.sqlite3
toner_report.txt
oid_profiles.json
oid_validation_errors.txt
missing_yield_printers.txt

# ─── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec

# ─── محیط مجازی ────────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── IDE و ادیتور ──────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# ─── سیستم‌عامل ────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
._*

# ─── فایل‌های موقت ─────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*.orig

# ─── لاگ‌های npm/node (اگر استفاده بشه) ─────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Docker ────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ─── فایل‌های حساس ─────────────────────────────────
.env
.env.*
*.pem
*.key
*.crt

# ─── گزارش‌های اضافی (workspace) ───────────────────
BUG_REPORT.md
FIXES.md
FINAL_REPORT.md
PATCH_poller.py.patch
SUMMARY.md
UI_REDESIGN_REPORT.md
UNUSED_FILES_REPORT.md
